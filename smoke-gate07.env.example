# Copy this to `.env.gate07` (or source it directly in shell).
# Required by:
#   npm run agent:p0-local-3d-runtime-sf3d-manual
#   npm run agent:p0-local-3d-runtime-triposr-manual

# 1) Core local backend selection used by Wushen runtime smoke:
export WUSHEN_3D_PROVIDER=local_http
export WUSHEN_3D_HTTP_BASE_URL=http://127.0.0.1:8787
export WUSHEN_GENERATE3D_ASYNC=1

###############################################################################
# SF3D manual smoke
###############################################################################
export WUSHEN_SF3D_REPO="$HOME/Models/Wushen/stable-fast-3d"
export WUSHEN_SF3D_PYTHON="$WUSHEN_SF3D_REPO/.venv/bin/python"
export WUSHEN_SF3D_SMOKE_OUTPUT_DIR="$HOME/WushenForge/output/sf3d-manual"
export WUSHEN_SF3D_SMOKE_MAX_WAIT_SECONDS=900
export WUSHEN_SF3D_SMOKE_POLL_INTERVAL_SECONDS=2
export WUSHEN_SF3D_SMOKE_KEEP_WORK_DIR=0

# Common optional SF3D tweaks (uncomment if needed):
# export WUSHEN_SF3D_TEXTURE_RESOLUTION=1024
# export WUSHEN_SF3D_REMESH_OPTION=triangle
# export SF3D_USE_CPU=1

# Optional source image override. If unset, smoke script uses built-in
# reference PNG for one-click reproducibility.
# export WUSHEN_SF3D_INPUT_IMAGE="$HOME/Models/Wushen/smoke-inputs/sf3d-input.png"

###############################################################################
# TripoSR manual smoke
###############################################################################
export WUSHEN_TRIPOSR_REPO="$HOME/Models/Wushen/TripoSR"
export WUSHEN_TRIPOSR_PYTHON="$WUSHEN_TRIPOSR_REPO/.venv/bin/python"
export WUSHEN_TRIPOSR_SMOKE_OUTPUT_DIR="$HOME/WushenForge/output/triposr-manual"
export WUSHEN_TRIPOSR_SMOKE_MAX_WAIT_SECONDS=900
export WUSHEN_TRIPOSR_SMOKE_POLL_INTERVAL_SECONDS=2
export WUSHEN_TRIPOSR_SMOKE_KEEP_WORK_DIR=0

# Common optional TripoSR tweaks (uncomment if needed):
# export WUSHEN_TRIPOSR_DEVICE=cuda:0
# export WUSHEN_TRIPOSR_PRETRAINED_MODEL=stabilityai/TripoSR
# export WUSHEN_TRIPOSR_CHUNK_SIZE=8192
# export WUSHEN_TRIPOSR_MC_RESOLUTION=256
# export WUSHEN_TRIPOSR_TEXTURE_RESOLUTION=2048
# export WUSHEN_TRIPOSR_BAKE_TEXTURE=1
# export WUSHEN_TRIPOSR_NO_REMOVE_BG=1

# Optional source image override. If unset, smoke script uses built-in
# reference PNG for one-click reproducibility.
# export WUSHEN_TRIPOSR_INPUT_IMAGE="$HOME/Models/Wushen/smoke-inputs/triposr-input.png"

###############################################################################
# Gate-10 helper (Unity gate): temporarily disable local_http binding.
###############################################################################
# export WUSHEN_3D_PROVIDER=mock
