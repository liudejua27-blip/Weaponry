{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/concept-export-manifest.schema.json",
  "title": "ConceptExportManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "export_id", "project_id", "version_id", "profile",
    "non_functional_only", "spec_sha256", "graph_sha256", "modules", "files", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "ConceptExportManifest@1" },
    "export_id": { "$ref": "common.schema.json#/$defs/id" },
    "project_id": { "$ref": "common.schema.json#/$defs/id" },
    "version_id": { "$ref": "common.schema.json#/$defs/id" },
    "profile": { "$ref": "common.schema.json#/$defs/intended_use" },
    "non_functional_only": { "const": true },
    "spec_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "graph_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "module_id", "asset_id", "sha256", "logical_path", "transform"],
        "properties": {
          "node_id": { "$ref": "common.schema.json#/$defs/id" },
          "module_id": { "$ref": "common.schema.json#/$defs/id" },
          "asset_id": { "$ref": "common.schema.json#/$defs/id" },
          "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "logical_path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "transform": { "$ref": "common.schema.json#/$defs/transform" }
        }
      }
    },
    "quality_report_id": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/id" },
        { "type": "null" }
      ]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "byte_size", "mime_type"],
        "properties": {
          "path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "byte_size": { "type": "integer", "minimum": 0 },
          "mime_type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
