{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/reference-evidence-create-request.schema.json",
  "title": "ReferenceEvidenceCreateRequest",
  "description": "R007 user-authorized reference intake. Image and GLB bytes are supplied directly as bounded raw content_base64 and sealed read-only into CAS; GLB may alternatively name a pre-existing same-project read-only import. Neither path edits or executes the reference object.",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "client_request_id", "project_id", "kind", "source_statement", "license_statement", "missing_views", "user_notes"],
  "properties": {
    "schema_version": { "const": "ReferenceEvidenceCreateRequest@1" },
    "client_request_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "project_id": { "type": "string", "pattern": "^(prj|project)_[a-z0-9_\\-]+$" },
    "kind": { "enum": ["image", "glb"] },
    "file_name": { "type": "string", "minLength": 1, "maxLength": 180 },
    "media_type": { "enum": ["image/png", "image/jpeg", "image/webp", "model/gltf-binary"] },
    "content_base64": { "type": "string", "minLength": 1, "maxLength": 44739244 },
    "imported_asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "source_statement": { "type": "string", "minLength": 1, "maxLength": 800 },
    "license_statement": { "type": "string", "minLength": 1, "maxLength": 800 },
    "missing_views": { "type": "array", "maxItems": 6, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80 } },
    "user_notes": { "type": "string", "maxLength": 1200 },
    "domain_pack_id": { "enum": ["pack_future_weapon_prop", "pack_vehicle_concept", "pack_aircraft_concept", "pack_robotic_arm_concept"] }
  },
  "allOf": [
    { "if": { "properties": { "kind": { "const": "image" } } }, "then": { "required": ["file_name", "media_type", "content_base64", "domain_pack_id"], "not": { "required": ["imported_asset_version_id"] } } },
    { "if": { "properties": { "kind": { "const": "glb" } } }, "then": { "oneOf": [
      { "required": ["imported_asset_version_id"], "not": { "anyOf": [{ "required": ["file_name"] }, { "required": ["media_type"] }, { "required": ["content_base64"] }] } },
      { "required": ["file_name", "media_type", "content_base64", "domain_pack_id"], "properties": { "media_type": { "const": "model/gltf-binary" } }, "not": { "required": ["imported_asset_version_id"] } }
    ] } }
  ]
}
