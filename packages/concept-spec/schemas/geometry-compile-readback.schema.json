{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/geometry-compile-readback.schema.json",
  "title": "GeometryCompileReadback",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "runtime_manifest_version",
    "program_id",
    "shape_program_sha256",
    "glb_sha256",
    "glb_byte_size",
    "triangle_count",
    "bounds_mm",
    "mesh_count",
    "primitive_count",
    "material_count",
    "uv0_primitive_count",
    "normal_primitive_count",
    "tangent_primitive_count",
    "surface_provenance",
    "material_zone_faces",
    "visual_texture_sets",
    "visual_environment",
    "operation_ids",
    "operation_names",
    "output_roles",
    "material_ids",
    "readback_status"
  ],
  "properties": {
    "schema_version": { "const": "GeometryCompileReadback@1" },
    "runtime_manifest_version": { "const": "ShapeProgramRuntimeManifest@1" },
    "program_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "shape_program_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "glb_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "glb_byte_size": { "type": "integer", "minimum": 20, "maximum": 67108864 },
    "triangle_count": { "type": "integer", "minimum": 1 },
    "bounds_mm": { "$ref": "common.schema.json#/$defs/vec3" },
    "mesh_count": { "type": "integer", "minimum": 1 },
    "primitive_count": { "type": "integer", "minimum": 1 },
    "material_count": { "type": "integer", "minimum": 0 },
    "uv0_primitive_count": { "type": "integer", "minimum": 1 },
    "normal_primitive_count": { "type": "integer", "minimum": 1 },
    "tangent_primitive_count": { "type": "integer", "minimum": 1 },
    "surface_provenance": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["primitive_id", "part_instance_id", "part_role", "profile_input_id", "surface_roles", "surface_ranges", "uv0_min", "uv0_max", "closed", "boundary_edge_count", "non_manifold_edge_count", "degenerate_triangle_count", "material_zone_id", "normal_mode", "tangent_min_length", "tangent_max_length", "tangent_handedness", "uv_degenerate_triangle_count", "tangent_fallback_triangle_count", "face_id_min", "face_id_max", "face_id_sha256", "edge_finish", "texture_ready"],
        "properties": {
          "primitive_id": { "type": "string", "pattern": "^primitive_[a-z0-9_\\-]+$" },
          "part_instance_id": { "type": "string", "pattern": "^partface_[a-z0-9_\\-]+$" },
          "part_role": { "type": "string", "minLength": 1, "maxLength": 64 },
          "profile_input_id": {
            "anyOf": [
              { "type": "string", "pattern": "^profileinput_[a-z0-9_\\-]+$" },
              { "type": "null" }
            ]
          },
          "surface_roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["surface", "side", "loft_side", "sweep_side", "hole_wall", "start_cap", "end_cap", "seam", "boolean_cut", "trim"] }
          },
          "surface_ranges": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["surface_role", "first_triangle", "triangle_count"],
              "properties": {
                "surface_role": { "type": "string", "enum": ["surface", "side", "loft_side", "sweep_side", "hole_wall", "start_cap", "end_cap", "seam", "boolean_cut", "trim"] },
                "first_triangle": { "type": "integer", "minimum": 0 },
                "triangle_count": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "uv0_min": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
          "uv0_max": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
          "closed": { "type": "boolean" },
          "boundary_edge_count": { "type": "integer", "minimum": 0 },
          "non_manifold_edge_count": { "type": "integer", "minimum": 0 },
          "degenerate_triangle_count": { "type": "integer", "minimum": 0 },
          "feature_node_id": {
            "anyOf": [
              { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" },
              { "type": "null" }
            ]
          },
          "source_operation_ids": {
            "type": "array",
            "maxItems": 32,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" }
          },
          "material_zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" },
          "boolean_backside": {
            "anyOf": [
              { "type": "boolean" },
              { "type": "null" }
            ]
          },
          "normal_mode": { "type": "string", "enum": ["split", "split_weighted"] },
          "tangent_min_length": { "type": "number", "minimum": 0.999, "maximum": 1.001 },
          "tangent_max_length": { "type": "number", "minimum": 0.999, "maximum": 1.001 },
          "tangent_handedness": { "type": "array", "minItems": 1, "maxItems": 2, "uniqueItems": true, "items": { "type": "integer", "enum": [-1, 1] } },
          "uv_degenerate_triangle_count": { "type": "integer", "minimum": 0 },
          "tangent_fallback_triangle_count": { "type": "integer", "minimum": 0 },
          "face_id_min": { "type": "integer", "minimum": 0 },
          "face_id_max": { "type": "integer", "minimum": 0 },
          "face_id_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "edge_finish": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "edge_set", "selected_edge_count", "radius_ratio", "subdivision_count"],
            "properties": {
              "mode": { "type": "string", "enum": ["none", "bevel_approximation"] },
              "edge_set": { "type": "string", "enum": ["none", "xz_perimeter"] },
              "selected_edge_count": { "type": "integer", "minimum": 0, "maximum": 4 },
              "radius_ratio": { "type": "number", "minimum": 0, "maximum": 0.25 },
              "subdivision_count": { "type": "integer", "minimum": 0, "maximum": 3 }
            }
          },
          "texture_ready": { "const": true }
        }
      }
    },
    "material_zone_faces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["primitive_id", "part_instance_id", "material_zone_id", "material_id", "face_count", "face_id_sha256", "surface_roles", "source_operation_ids", "texture_ready"],
        "properties": {
          "primitive_id": { "type": "string", "pattern": "^primitive_[a-z0-9_\\-]+$" },
          "part_instance_id": { "type": "string", "pattern": "^partface_[a-z0-9_\\-]+$" },
          "material_zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" },
          "material_id": { "type": "string", "pattern": "^mat_[a-z0-9_\\-]+$" },
          "face_count": { "type": "integer", "minimum": 1 },
          "face_id_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "surface_roles": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "type": "string", "enum": ["surface", "side", "loft_side", "sweep_side", "hole_wall", "start_cap", "end_cap", "seam", "boolean_cut", "trim"] } },
          "source_operation_ids": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" } },
          "texture_ready": { "const": true }
        }
      }
    },
    "visual_texture_sets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "visual_texture_set_id", "material_id", "texture_material_id", "material_index", "material_zone_ids", "maps", "extensions", "texture_byte_size"],
        "properties": {
          "schema_version": { "const": "VisualTextureSet@1" },
          "visual_texture_set_id": { "type": "string", "pattern": "^vtexset_[a-z0-9_\\-]+$" },
          "material_id": { "type": "string", "pattern": "^mat_[a-z0-9_\\-]+$" },
          "texture_material_id": { "type": "string", "pattern": "^mat_[a-z0-9_\\-]+$" },
          "material_index": { "type": "integer", "minimum": 0 },
          "material_zone_ids": { "type": "array", "minItems": 1, "maxItems": 512, "uniqueItems": true, "items": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" } },
          "maps": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["texture_id", "texture_role", "mime_type", "byte_size", "sha256", "color_space", "width", "height", "source", "license", "fallback", "glb_image_index", "glb_texture_index"],
              "properties": {
                "texture_id": { "type": "string", "pattern": "^vtex_[a-z0-9_\\-]+$" },
                "texture_role": { "type": "string", "enum": ["base_color", "metallic_roughness", "normal", "occlusion", "emissive"] },
                "mime_type": { "const": "image/png" },
                "byte_size": { "type": "integer", "minimum": 1, "maximum": 4000000 },
                "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
                "color_space": { "type": "string", "enum": ["srgb", "linear"] },
                "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
                "height": { "type": "integer", "minimum": 1, "maximum": 4096 },
                "source": { "const": "forgecad_builtin" },
                "license": { "const": "not_applicable" },
                "fallback": { "type": "string", "enum": ["none", "parameter", "unavailable"] },
                "glb_image_index": { "type": "integer", "minimum": 0 },
                "glb_texture_index": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "extensions": { "type": "array", "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "enum": ["KHR_materials_clearcoat", "KHR_materials_transmission", "KHR_materials_ior"] } },
          "texture_byte_size": { "type": "integer", "minimum": 1, "maximum": 20000000 }
        }
      }
    },
    "visual_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "environment_id", "environment_kind", "environment_sha256", "source", "license", "color_workflow", "output_color_space", "tone_mapping", "tone_mapping_exposure", "contact_shadows", "pmrem"],
      "properties": {
        "schema_version": { "const": "ForgeCADVisualEnvironment@1" },
        "environment_id": { "type": "string", "pattern": "^env_[a-z0-9_\\-]+$" },
        "environment_kind": { "const": "procedural_studio" },
        "environment_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "source": { "const": "forgecad_builtin" },
        "license": { "const": "not_applicable" },
        "color_workflow": { "const": "linear_srgb" },
        "output_color_space": { "const": "srgb" },
        "tone_mapping": { "const": "aces_filmic" },
        "tone_mapping_exposure": { "type": "number", "minimum": 0.1, "maximum": 3 },
        "contact_shadows": { "const": true },
        "pmrem": { "type": "object", "additionalProperties": false, "required": ["near", "cube_size"], "properties": { "near": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }, "cube_size": { "const": 128 } } }
      }
    },
    "feature_history": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "node_id",
          "operation",
          "input_node_ids",
          "input_hashes",
          "parameters_sha256",
          "node_input_sha256",
          "result_sha256",
          "surface_provenance_sha256",
          "runtime_manifest_version",
          "kernel_id",
          "kernel_version",
          "csg_depth",
          "result_triangle_count",
          "result_closed",
          "material_ids",
          "material_zone_ids",
          "surface_roles"
        ],
        "properties": {
          "schema_version": { "const": "GeometryFeatureNodeReadback@1" },
          "node_id": { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" },
          "operation": { "type": "string", "minLength": 1, "maxLength": 64 },
          "input_node_ids": {
            "type": "array",
            "maxItems": 8,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" }
          },
          "input_hashes": {
            "type": "array",
            "maxItems": 8,
            "items": { "$ref": "common.schema.json#/$defs/sha256" }
          },
          "parameters_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "node_input_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "result_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "surface_provenance_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
          "runtime_manifest_version": { "const": "ShapeProgramRuntimeManifest@1" },
          "kernel_id": { "type": "string", "enum": ["forgecad_builtin", "manifold3d"] },
          "kernel_version": { "type": "string", "minLength": 1, "maxLength": 64 },
          "csg_depth": { "type": "integer", "minimum": 0, "maximum": 8 },
          "result_triangle_count": { "type": "integer", "minimum": 0 },
          "result_closed": { "type": "boolean" },
          "material_ids": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "material_zone_ids": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" } },
          "surface_roles": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["surface", "side", "loft_side", "sweep_side", "hole_wall", "start_cap", "end_cap", "seam", "boolean_cut", "trim"] }
          }
        }
      }
    },
    "operation_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "operation_names": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": { "type": "string", "minLength": 1 }
    },
    "output_roles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": { "type": "string", "minLength": 1 }
    },
    "material_ids": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "readback_status": { "const": "passed" }
  }
}
