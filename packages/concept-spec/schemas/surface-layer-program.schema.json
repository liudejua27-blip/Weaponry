{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/surface-layer-program.schema.json",
  "title": "SurfaceLayerProgram",
  "description": "A bounded 2D Design Surface language. It carries normalized vector paths, built-in decal and PBR mask tokens, symmetry and UV framing. It never embeds SVG strings, scripts, URLs, file paths, geometry operations or executable content. Exact normal-relief semantics lower to A005 and retained layers are compiled by the reviewed deterministic five-channel PBR path.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "program_id", "target_part_id", "target_zone_id", "target_part_role", "material_zone_id", "base_material", "vector_paths", "decal_layers", "normal_relief_layers", "roughness_masks", "emissive_masks", "symmetry", "uv_frame", "quality_profile", "execution", "skill_id", "skill_version", "skill_sha256", "generator", "non_functional_only"],
  "properties": {
    "schema_version": { "const": "SurfaceLayerProgram@1" },
    "program_id": { "type": "string", "pattern": "^surface_layer_[a-z0-9_\\-]+$" },
    "target_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$", "description": "Compatibility mapping to the current stable AssemblyGraph part." },
    "target_zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$", "description": "Compatibility mapping to the current stable Material Zone." },
    "target_part_role": { "enum": ["base_form", "turntable", "joint_housing", "link_armor", "cable_harness", "end_effector_form", "surface_trim"] },
    "material_zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" },
    "base_material": { "enum": ["mat_aluminum", "mat_automotive_paint", "mat_composite", "mat_dark_glass", "mat_emissive_blue", "mat_graphite", "mat_rubber", "mat_signal_red"] },
    "vector_paths": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path_id", "closed", "commands"],
        "properties": {
          "path_id": { "type": "string", "pattern": "^path_[a-z0-9_\\-]+$" },
          "closed": { "type": "boolean" },
          "commands": {
            "type": "array",
            "minItems": 2,
            "maxItems": 32,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "points"],
              "properties": {
                "kind": { "enum": ["move", "line", "quadratic", "cubic"] },
                "points": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 3,
                  "items": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              },
              "allOf": [
                { "if": { "properties": { "kind": { "enum": ["move", "line"] } } }, "then": { "properties": { "points": { "minItems": 1, "maxItems": 1 } } } },
                { "if": { "properties": { "kind": { "const": "quadratic" } } }, "then": { "properties": { "points": { "minItems": 2, "maxItems": 2 } } } },
                { "if": { "properties": { "kind": { "const": "cubic" } } }, "then": { "properties": { "points": { "minItems": 3, "maxItems": 3 } } } }
              ]
            }
          }
        }
      }
    },
    "decal_layers": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decal_id", "motif", "text_token", "color_token", "anchor_uv", "scale_milli", "opacity_milli"],
        "properties": {
          "decal_id": { "type": "string", "pattern": "^decal_[a-z0-9_\\-]+$" },
          "motif": { "enum": ["chevron_mark", "hex_badge", "warning_stripe", "panel_label"] },
          "text_token": { "enum": ["none", "A-01", "SERVICE", "CAUTION", "01"] },
          "color_token": { "enum": ["accent_blue", "signal_red", "graphite", "aluminum"] },
          "anchor_uv": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": 0, "maximum": 1 } },
          "scale_milli": { "type": "integer", "minimum": 50, "maximum": 500 },
          "opacity_milli": { "type": "integer", "minimum": 0, "maximum": 1000 }
        }
      }
    },
    "normal_relief_layers": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer_id", "motif", "intensity", "coverage", "seed"],
        "properties": {
          "layer_id": { "type": "string", "pattern": "^relief_[a-z0-9_\\-]+$" },
          "motif": { "enum": ["parallel_groove", "chevron_relief"] },
          "intensity": { "enum": ["subtle", "balanced", "pronounced"] },
          "coverage": { "enum": ["full_zone", "center_band", "edge_band", "symmetric_pair"] },
          "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
        }
      }
    },
    "roughness_masks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mask_id", "motif", "coverage", "intensity_milli", "seed"],
        "properties": {
          "mask_id": { "type": "string", "pattern": "^rough_[a-z0-9_\\-]+$" },
          "motif": { "enum": ["linear_brush", "edge_wear", "microgrid"] },
          "coverage": { "enum": ["full_zone", "center_band", "edge_band", "symmetric_pair"] },
          "intensity_milli": { "type": "integer", "minimum": 0, "maximum": 1000 },
          "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
        }
      }
    },
    "emissive_masks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mask_id", "motif", "color_token", "coverage", "intensity_milli", "seed"],
        "properties": {
          "mask_id": { "type": "string", "pattern": "^emissive_[a-z0-9_\\-]+$" },
          "motif": { "enum": ["double_flowline", "dot_array", "panel_indicator"] },
          "color_token": { "enum": ["accent_blue", "signal_red"] },
          "coverage": { "enum": ["full_zone", "center_band", "edge_band", "symmetric_pair"] },
          "intensity_milli": { "type": "integer", "minimum": 0, "maximum": 1000 },
          "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
        }
      }
    },
    "symmetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "center_uv"],
      "properties": {
        "mode": { "enum": ["none", "mirror_u", "mirror_v", "radial_2", "radial_4"] },
        "center_uv": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": 0, "maximum": 1 } }
      }
    },
    "uv_frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame_id", "u_min", "u_max", "v_min", "v_max", "rotation_degrees"],
      "properties": {
        "frame_id": { "type": "string", "pattern": "^uvframe_[a-z0-9_\\-]+$" },
        "u_min": { "type": "number", "minimum": 0, "maximum": 1 },
        "u_max": { "type": "number", "minimum": 0, "maximum": 1 },
        "v_min": { "type": "number", "minimum": 0, "maximum": 1 },
        "v_max": { "type": "number", "minimum": 0, "maximum": 1 },
        "rotation_degrees": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "quality_profile": { "enum": ["interactive_preview", "production_concept"] },
    "execution": { "const": "lower_to_a005_and_retain" },
    "skill_id": { "type": "string", "pattern": "^skill_[a-z0-9_\\-]+$" },
    "skill_version": { "type": "integer", "minimum": 1 },
    "skill_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "generator": { "const": "surface_layer_v1" },
    "non_functional_only": { "const": true }
  }
}
