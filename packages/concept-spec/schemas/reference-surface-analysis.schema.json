{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/reference-surface-analysis.schema.json",
  "title": "ReferenceSurfaceAnalysis",
  "description": "R007B's sealed visible-evidence mapping to one reviewed C106 robotic-arm design surface. It never embeds source pixels, source GLB topology, URLs, paths, hidden structure, engineering dimensions or functional facts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "analysis_id", "rebuild_plan_id", "evidence_id", "source_object_sha256", "domain_pack_id", "target_root_recipe", "c106_registry_sha256", "surface_skill_id", "surface_skill_version", "surface_skill_sha256", "fidelity_ceiling", "bindings", "retained_observation_kinds", "intentionally_changed", "unresolved", "created_at"],
  "properties": {
    "schema_version": { "const": "ReferenceSurfaceAnalysis@1" },
    "analysis_id": { "type": "string", "pattern": "^refsrfanalysis_[a-z0-9_\\-]+$" },
    "rebuild_plan_id": { "type": "string", "pattern": "^rebuildplan_[a-z0-9_\\-]+$" },
    "evidence_id": { "type": "string", "pattern": "^refevid_[a-z0-9_\\-]+$" },
    "source_object_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "domain_pack_id": { "const": "pack_robotic_arm_concept" },
    "target_root_recipe": { "$ref": "component-recipe-ref.schema.json" },
    "c106_registry_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "surface_skill_id": { "const": "skill_first_party_surface_adornment" },
    "surface_skill_version": { "const": 2 },
    "surface_skill_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "fidelity_ceiling": { "enum": ["single_image_visible_surface_only", "multi_view_image_visible_surface_only", "strict_glb_readback_visible_bounds_only"] },
    "bindings": { "type": "array", "minItems": 3, "maxItems": 16, "items": { "$ref": "reference-surface-analysis.schema.json#/$defs/binding" } },
    "retained_observation_kinds": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "$ref": "reference-surface-analysis.schema.json#/$defs/observation_kind" } },
    "intentionally_changed": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "enum": ["non_functional_recipe_interpretation", "reviewed_recipe_component_substitution", "material_preset_normalization", "surface_adornment_normalization"] } },
    "unresolved": { "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": { "enum": ["missing_views", "hidden_structure", "exact_dimensions", "material_physics", "functional_behavior"] } },
    "glb_readback_facts": { "anyOf": [{ "$ref": "reference-surface-analysis.schema.json#/$defs/glb_readback_facts" }, { "type": "null" }] },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  },
  "$defs": {
    "observation_kind": { "enum": ["silhouette", "proportion", "visible_part", "material_zone"] },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_id", "observation_kind", "observation_index", "target_recipe", "target_part_role", "target_material_zone_id", "target_surface_slot_id"],
      "properties": {
        "binding_id": { "type": "string", "pattern": "^refsrfbind_[a-z0-9_\\-]+$" },
        "observation_kind": { "$ref": "reference-surface-analysis.schema.json#/$defs/observation_kind" },
        "observation_index": { "type": "integer", "minimum": 0, "maximum": 15 },
        "target_part_slot_id": { "type": ["string", "null"], "pattern": "^slot_[a-z0-9_\\-]+$" },
        "target_recipe": { "$ref": "component-recipe-ref.schema.json" },
        "target_part_role": { "enum": ["base_form", "turntable", "joint_housing", "link_armor", "cable_harness", "end_effector_form", "surface_trim"] },
        "target_material_zone_id": { "type": "string", "pattern": "^zone_arm_[a-z0-9_\\-]+$" },
        "target_surface_slot_id": { "type": "string", "pattern": "^adornslot_[a-z0-9_\\-]+$" }
      }
    },
    "glb_readback_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "triangle_count", "bounds_mm", "mesh_count", "primitive_count", "material_count", "node_count"],
      "properties": {
        "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
        "triangle_count": { "type": "integer", "minimum": 1 },
        "bounds_mm": { "$ref": "common.schema.json#/$defs/vec3" },
        "mesh_count": { "type": "integer", "minimum": 1 },
        "primitive_count": { "type": "integer", "minimum": 1 },
        "material_count": { "type": "integer", "minimum": 0 },
        "node_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
