{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/reference-evidence.schema.json",
  "title": "ReferenceEvidence",
  "description": "Immutable R007 evidence. Observations are server-derived visible-language evidence, never recovered hidden structure or engineering facts.",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "project_id", "kind", "domain_pack_id", "source_file_name", "source_media_type", "source_object_sha256", "source_statement", "license_statement", "missing_views", "user_notes", "observations", "created_at"],
  "properties": {
    "schema_version": { "const": "ReferenceEvidence@1" },
    "evidence_id": { "type": "string", "pattern": "^refevid_[a-z0-9_\\-]+$" },
    "project_id": { "type": "string", "pattern": "^(prj|project)_[a-z0-9_\\-]+$" },
    "kind": { "enum": ["image", "glb"] },
    "domain_pack_id": { "enum": ["pack_future_weapon_prop", "pack_vehicle_concept", "pack_aircraft_concept", "pack_robotic_arm_concept"] },
    "source_file_name": { "type": "string", "minLength": 1, "maxLength": 180 },
    "source_media_type": { "enum": ["image/png", "image/jpeg", "image/webp", "model/gltf-binary"] },
    "source_object_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "source_imported_asset_version_id": { "type": ["string", "null"], "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "source_statement": { "type": "string", "minLength": 1, "maxLength": 800 },
    "license_statement": { "type": "string", "minLength": 1, "maxLength": 800 },
    "missing_views": { "type": "array", "maxItems": 6, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80 } },
    "user_notes": { "type": "string", "maxLength": 1200 },
    "observations": {
      "type": "object", "additionalProperties": false,
      "required": ["silhouette_summary", "proportion_ranges", "material_zone_observations", "visible_part_hypotheses", "uncertainties"],
      "properties": {
        "silhouette_summary": { "type": "string", "minLength": 1, "maxLength": 600 },
        "proportion_ranges": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
        "material_zone_observations": { "type": "array", "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
        "visible_part_hypotheses": { "type": "array", "maxItems": 16, "items": { "type": "object", "additionalProperties": false, "required": ["role", "confidence", "visible_basis"], "properties": { "role": { "type": "string", "minLength": 1, "maxLength": 120 }, "confidence": { "enum": ["low", "medium", "high"] }, "visible_basis": { "type": "string", "minLength": 1, "maxLength": 320 } } } },
        "uncertainties": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "minLength": 1, "maxLength": 320 } },
        "image_surface_facts": {
          "type": ["object", "null"], "additionalProperties": false,
          "required": ["width", "height", "aspect_ratio_milli", "dominant_color_buckets", "brightness", "edge_density", "foreground_bbox_normalized", "foreground_confidence"],
          "properties": {
            "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "height": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "aspect_ratio_milli": { "type": "integer", "minimum": 1, "maximum": 64000 },
            "dominant_color_buckets": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "enum": ["black", "gray", "white", "blue", "cyan", "red", "yellow", "green", "violet"] } },
            "brightness": { "enum": ["dark", "balanced", "bright"] },
            "edge_density": { "enum": ["low", "medium", "high"] },
            "foreground_bbox_normalized": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "integer", "minimum": 0, "maximum": 1000 } },
            "foreground_confidence": { "enum": ["low", "medium"] }
          }
        }
      }
    },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" },
    "glb_inspection": { "type": ["object", "null"], "additionalProperties": false, "required": ["sha256", "byte_size", "triangle_count", "bounds_mm", "mesh_count", "primitive_count", "material_count", "node_count"], "properties": { "sha256": { "$ref": "common.schema.json#/$defs/sha256" }, "byte_size": { "type": "integer", "minimum": 20 }, "triangle_count": { "type": "integer", "minimum": 1 }, "bounds_mm": { "$ref": "common.schema.json#/$defs/vec3" }, "mesh_count": { "type": "integer", "minimum": 1 }, "primitive_count": { "type": "integer", "minimum": 1 }, "material_count": { "type": "integer", "minimum": 0 }, "node_count": { "type": "integer", "minimum": 0 } } }
  },
  "$defs": {
    "observations": { "type": "object", "additionalProperties": false, "required": ["silhouette_summary", "proportion_ranges", "material_zone_observations", "visible_part_hypotheses", "uncertainties"], "properties": { "silhouette_summary": { "type": "string", "minLength": 1, "maxLength": 600 }, "proportion_ranges": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 240 } }, "material_zone_observations": { "type": "array", "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 240 } }, "visible_part_hypotheses": { "type": "array", "maxItems": 16, "items": { "type": "object", "additionalProperties": false, "required": ["role", "confidence", "visible_basis"], "properties": { "role": { "type": "string", "minLength": 1, "maxLength": 120 }, "confidence": { "enum": ["low", "medium", "high"] }, "visible_basis": { "type": "string", "minLength": 1, "maxLength": 320 } } } }, "uncertainties": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "minLength": 1, "maxLength": 320 } } } }
  },
  "allOf": [
    { "if": { "properties": { "kind": { "const": "image" } } }, "then": { "properties": { "source_media_type": { "enum": ["image/png", "image/jpeg", "image/webp"] }, "source_imported_asset_version_id": { "const": null }, "glb_inspection": { "const": null }, "observations": { "required": ["image_surface_facts"], "properties": { "image_surface_facts": { "type": "object" } } } } } },
    { "if": { "properties": { "kind": { "const": "glb" } } }, "then": { "required": ["glb_inspection"], "properties": { "source_media_type": { "const": "model/gltf-binary" }, "observations": { "properties": { "image_surface_facts": { "const": null } } } } } }
  ]
}
