{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/reference-guided-rebuild-plan.schema.json",
  "title": "ReferenceGuidedRebuildPlan",
  "description": "Immutable-identity R007 rebuild intent. It links only to the normal ChangeSet preview/confirm lifecycle and never edits an imported GLB.",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "rebuild_plan_id", "project_id", "evidence_id", "domain_pack_id", "recipe_id", "recipe_registry_sha256", "rebuild_summary", "intended_differences", "retained_evidence", "unresolved_uncertainties", "status", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "ReferenceGuidedRebuildPlan@1" },
    "rebuild_plan_id": { "type": "string", "pattern": "^rebuildplan_[a-z0-9_\\-]+$" },
    "project_id": { "type": "string", "pattern": "^(prj|project)_[a-z0-9_\\-]+$" },
    "evidence_id": { "type": "string", "pattern": "^refevid_[a-z0-9_\\-]+$" },
    "base_asset_version_id": { "type": ["string", "null"], "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "domain_pack_id": { "enum": ["pack_future_weapon_prop", "pack_vehicle_concept", "pack_aircraft_concept", "pack_robotic_arm_concept"] },
    "recipe_id": { "type": "string", "pattern": "^recipe_[a-z0-9_\\-]+$" },
    "recipe_registry_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "rebuild_summary": { "type": "string", "minLength": 1, "maxLength": 800 },
    "intended_differences": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "minLength": 1, "maxLength": 320 } },
    "retained_evidence": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "minLength": 1, "maxLength": 320 } },
    "unresolved_uncertainties": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "minLength": 1, "maxLength": 320 } },
    "status": { "enum": ["draft", "previewed", "confirmed", "rejected"] },
    "preview_change_set_id": { "type": ["string", "null"], "pattern": "^changeset_[a-z0-9_\\-]+$" },
    "confirmed_asset_version_id": { "type": ["string", "null"], "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" },
    "updated_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
