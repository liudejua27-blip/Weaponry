{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/design-domain-profile.schema.json",
  "title": "DesignDomainProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "domain_type",
    "display_name",
    "pack_id",
    "intended_uses",
    "module_categories",
    "required_connectors",
    "optional_connectors",
    "export_profiles",
    "non_functional_only"
  ],
  "properties": {
    "schema_version": { "const": "DesignDomainProfile@1" },
    "profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "domain_type": { "const": "weapon_concept" },
    "display_name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "pack_id": { "$ref": "common.schema.json#/$defs/id" },
    "intended_uses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/intended_use" }
    },
    "module_categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/module_category" }
    },
    "required_connectors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$" }
    },
    "optional_connectors": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$" }
    },
    "export_profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/intended_use" }
    },
    "non_functional_only": { "const": true }
  }
}
