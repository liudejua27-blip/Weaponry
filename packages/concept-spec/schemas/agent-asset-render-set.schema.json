{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/agent-asset-render-set.schema.json",
  "title": "AgentAssetRenderSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "asset_version_id", "renderer_id", "width", "height", "views", "exploded_view_available", "render_set_sha256", "render_set_byte_size", "rendered_at"],
  "properties": {
    "schema_version": { "const": "AgentAssetRenderSet@1" },
    "asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "renderer_id": { "const": "forgecad-agent-software-raster@1" },
    "width": { "type": "integer", "minimum": 64, "maximum": 2048 },
    "height": { "type": "integer", "minimum": 64, "maximum": 2048 },
    "views": { "type": "array", "minItems": 4, "maxItems": 5, "items": { "$ref": "#/$defs/view" } },
    "exploded_view_available": { "type": "boolean" },
    "exploded_unavailable_reason": { "type": ["string", "null"], "maxLength": 300 },
    "render_set_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "render_set_byte_size": { "type": "integer", "minimum": 96 },
    "rendered_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  },
  "$defs": {
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "asset_version_id", "view_id", "camera_view", "presentation_mode", "background_mode", "part_ids", "mime_type", "width", "height", "png_base64", "sha256", "byte_size", "readback_status"],
      "properties": {
        "schema_version": { "const": "AgentAssetRenderView@1" },
        "asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
        "view_id": { "enum": ["iso", "front", "side", "top", "exploded_iso"] },
        "camera_view": { "enum": ["iso", "front", "side", "top"] },
        "presentation_mode": { "enum": ["standard", "exploded"] },
        "background_mode": { "const": "transparent" },
        "part_ids": { "type": "array", "items": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" }, "maxItems": 128 },
        "mime_type": { "const": "image/png" },
        "width": { "type": "integer", "minimum": 64, "maximum": 2048 },
        "height": { "type": "integer", "minimum": 64, "maximum": 2048 },
        "png_base64": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "byte_size": { "type": "integer", "minimum": 24 },
        "readback_status": { "const": "passed" }
      }
    }
  }
}
