{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/shape-program.schema.json",
  "title": "ShapeProgram",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "program_id",
    "units",
    "seed",
    "triangle_budget",
    "parameters",
    "operations",
    "outputs",
    "non_functional_only"
  ],
  "properties": {
    "schema_version": {
      "const": "ShapeProgram@1"
    },
    "program_id": {
      "type": "string",
      "pattern": "^shape_[a-z0-9_\\-]+$"
    },
    "units": {
      "const": "millimeter"
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "triangle_budget": {
      "type": "integer",
      "minimum": 100,
      "maximum": 100000
    },
    "parameters": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "parameter_id",
          "default",
          "min",
          "max"
        ],
        "properties": {
          "parameter_id": {
            "type": "string",
            "pattern": "^param_[a-z0-9_\\-]+$"
          },
          "default": {
            "type": "number"
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        }
      }
    },
    "profile_inputs": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input_id",
          "input_kind",
          "contract_version",
          "input_sha256",
          "canonical_payload"
        ],
        "properties": {
          "input_id": {
            "type": "string",
            "pattern": "^profileinput_[a-z0-9_\\-]+$"
          },
          "input_kind": {
            "type": "string",
            "enum": [
              "profile_sketch",
              "profile_section_set"
            ]
          },
          "contract_version": {
            "type": "string",
            "enum": [
              "ProfileSketch@1",
              "ProfileSectionSet@1"
            ]
          },
          "input_sha256": {
            "$ref": "common.schema.json#/$defs/sha256"
          },
          "canonical_payload": {
            "anyOf": [
              {
                "$ref": "profile-sketch.schema.json"
              },
              {
                "$ref": "profile-section-set.schema.json"
              }
            ]
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operation_id",
          "op",
          "inputs",
          "args"
        ],
        "properties": {
          "operation_id": {
            "type": "string",
            "pattern": "^op_[a-z0-9_\\-]+$"
          },
          "op": {
            "type": "string",
            "enum": [
              "box",
              "cylinder",
              "capsule",
              "wedge",
              "profile",
              "extrude",
              "revolve",
              "loft",
              "sweep",
              "mirror",
              "array",
              "radial_array",
              "union",
              "subtract",
              "bevel_approx",
              "surface_panel"
            ]
          },
          "inputs": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "string",
              "pattern": "^op_[a-z0-9_\\-]+$"
            }
          },
          "args": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "size": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              },
              "radius": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "angle": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 6.283185307179586
              },
              "spacing": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "position": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              },
              "rotation": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              },
              "axis": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              },
              "count": {
                "type": "integer",
                "minimum": 1,
                "maximum": 64
              },
              "segments": {
                "type": "integer",
                "minimum": 1,
                "maximum": 3
              },
              "points": {
                "type": "array",
                "minItems": 3,
                "maxItems": 32,
                "items": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": {
                    "type": "number"
                  }
                }
              },
              "profile_input_id": {
                "type": "string",
                "pattern": "^profileinput_[a-z0-9_\\-]+$"
              },
              "profile_scale": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 100000
                }
              },
              "cap_start": {
                "type": "boolean"
              },
              "cap_end": {
                "type": "boolean"
              },
              "radial_segments": {
                "type": "integer",
                "minimum": 8,
                "maximum": 64
              },
              "section_set_input_id": {
                "type": "string",
                "pattern": "^profileinput_[a-z0-9_\\-]+$"
              },
              "cross_section_scale": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 100000
                }
              },
              "axis_length": {
                "type": "number",
                "exclusiveMinimum": 0,
                "maximum": 100000
              },
              "continuity": {
                "type": "string",
                "enum": [
                  "linear"
                ]
              },
              "path_points": {
                "type": "array",
                "minItems": 2,
                "maxItems": 32,
                "items": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 3,
                  "items": {
                    "type": "number",
                    "minimum": -100000,
                    "maximum": 100000
                  }
                }
              },
              "path_closed": {
                "type": "boolean"
              },
              "path_twist_degrees": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "parameter_id": {
                "type": "string",
                "pattern": "^param_[a-z0-9_\\-]+$"
              },
              "part_role": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
              },
              "zone_id": {
                "type": "string",
                "pattern": "^zone_[a-z0-9_\\-]+$"
              },
              "connector_kind": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
              },
              "joint_kind": {
                "type": "string",
                "enum": [
                  "fixed",
                  "hinge",
                  "slider",
                  "ball",
                  "continuous"
                ]
              },
              "material_id": {
                "type": "string",
                "pattern": "^mat_[a-z0-9_\\-]+$"
              }
            }
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 96,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "output_id",
          "operation_id",
          "kind",
          "part_role"
        ],
        "properties": {
          "output_id": {
            "type": "string",
            "pattern": "^output_[a-z0-9_\\-]+$"
          },
          "operation_id": {
            "type": "string",
            "pattern": "^op_[a-z0-9_\\-]+$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "mesh",
              "assembly_graph"
            ]
          },
          "part_role": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
          }
        }
      }
    },
    "non_functional_only": {
      "const": true
    }
  }
}
