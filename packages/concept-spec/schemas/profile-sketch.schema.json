{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/profile-sketch.schema.json",
  "title": "ProfileSketch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sketch_id",
    "version",
    "plane",
    "closed",
    "winding",
    "start",
    "segments",
    "holes",
    "normalized_bounds",
    "symmetry",
    "continuity_hint",
    "resample_count",
    "provenance"
  ],
  "properties": {
    "schema_version": { "const": "ProfileSketch@1" },
    "sketch_id": { "type": "string", "pattern": "^sketch_[a-z0-9_\\-]+$" },
    "version": { "const": 1 },
    "plane": { "type": "string", "enum": ["front", "side", "top", "cross_section"] },
    "closed": { "type": "boolean" },
    "winding": { "type": "string", "enum": ["open", "clockwise", "counter_clockwise"] },
    "start": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number", "minimum": -1, "maximum": 1 }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "to"],
            "properties": {
              "kind": { "const": "line" },
              "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "control", "to"],
            "properties": {
              "kind": { "const": "quadratic" },
              "control": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
              "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "control_1", "control_2", "to"],
            "properties": {
              "kind": { "const": "cubic" },
              "control_1": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
              "control_2": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
              "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
            }
          }
        ]
      }
    },
    "holes": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hole_id", "winding", "start", "segments"],
        "properties": {
          "hole_id": { "type": "string", "pattern": "^hole_[a-z0-9_\\-]+$" },
          "winding": { "type": "string", "enum": ["clockwise", "counter_clockwise"] },
          "start": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
          "segments": {
            "type": "array",
            "minItems": 3,
            "maxItems": 64,
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "to"],
                  "properties": {
                    "kind": { "const": "line" },
                    "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "control", "to"],
                  "properties": {
                    "kind": { "const": "quadratic" },
                    "control": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
                    "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "control_1", "control_2", "to"],
                  "properties": {
                    "kind": { "const": "cubic" },
                    "control_1": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
                    "control_2": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
                    "to": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "normalized_bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
        "max": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -1, "maximum": 1 } }
      }
    },
    "symmetry": { "type": "string", "enum": ["none", "horizontal", "vertical", "radial"] },
    "continuity_hint": { "type": "string", "enum": ["linear", "tangent", "smooth"] },
    "resample_count": { "type": "integer", "minimum": 8, "maximum": 256 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": { "type": "string", "enum": ["agent", "svg_editor", "component_recipe", "reference_rebuild"] },
        "source_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,119}$" }
      }
    }
  }
}
