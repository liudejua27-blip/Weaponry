{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/agent-component-compatibility.schema.json",
  "title": "AgentComponentCompatibility",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "component_id", "target_asset_version_id", "target_part_id", "eligible", "source_quality_status", "reason_codes"],
  "properties": {
    "schema_version": { "const": "AgentComponentCompatibility@1" },
    "component_id": { "type": "string", "pattern": "^agentcomp_[a-z0-9_\\-]+$" },
    "target_asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "target_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
    "eligible": { "type": "boolean" },
    "source_quality_status": { "type": "string", "enum": ["passed", "warning", "failed", "unavailable"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "same_domain_pack",
          "domain_pack_mismatch",
          "same_role",
          "role_mismatch",
          "component_active",
          "component_disabled",
          "source_quality_passed",
          "source_quality_warning",
          "source_quality_failed",
          "source_quality_unavailable",
          "target_connectors_preserved"
        ]
      }
    }
  }
}
