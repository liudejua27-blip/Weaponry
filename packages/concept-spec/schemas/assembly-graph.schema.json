{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/assembly-graph.schema.json",
  "title": "AssemblyGraph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "graph_id", "concept_id", "root_part_id", "parts", "connections"],
  "properties": {
    "schema_version": { "const": "AssemblyGraph@1" },
    "graph_id": { "$ref": "common.schema.json#/$defs/id" },
    "concept_id": { "$ref": "common.schema.json#/$defs/id" },
    "root_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["part_id", "role", "parent_part_id", "geometry_source", "transform", "connectors", "joints", "material_zones", "editable_parameters", "locked", "provenance"],
        "properties": {
          "part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
          "role": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" },
          "parent_part_id": { "type": ["string", "null"], "pattern": "^part_[a-z0-9_\\-]+$" },
          "geometry_source": { "type": "string", "enum": ["shape_program", "module_asset", "imported_reference"] },
          "transform": { "$ref": "common.schema.json#/$defs/transform" },
          "connectors": { "type": "array", "items": { "$ref": "#/definitions/connector" } },
          "joints": { "type": "array", "items": { "$ref": "#/definitions/joint" } },
          "material_zones": { "type": "array", "items": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" } },
          "editable_parameters": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" } },
          "locked": { "type": "boolean" },
          "provenance": { "type": "string", "enum": ["agent_generated", "user_created", "imported"] }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["connection_id", "from_part_id", "from_connector_id", "to_part_id", "to_connector_id", "status"],
        "properties": {
          "connection_id": { "type": "string", "pattern": "^conn_[a-z0-9_\\-]+$" },
          "from_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
          "from_connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" },
          "to_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
          "to_connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" },
          "status": { "type": "string", "enum": ["connected", "invalid"] }
        }
      }
    }
  },
  "definitions": {
    "connector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connector_id", "kind", "position", "normal"],
      "properties": {
        "connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" },
        "kind": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" },
        "position": { "$ref": "common.schema.json#/$defs/vec3" },
        "normal": { "$ref": "common.schema.json#/$defs/vec3" }
      }
    },
    "joint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["joint_id", "kind", "target_part_id", "axis", "min_value", "max_value"],
      "properties": {
        "joint_id": { "type": "string", "pattern": "^joint_[a-z0-9_\\-]+$" },
        "kind": { "type": "string", "enum": ["fixed", "hinge", "slider", "ball", "continuous"] },
        "target_part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
        "axis": { "$ref": "common.schema.json#/$defs/vec3" },
        "min_value": { "type": "number" },
        "max_value": { "type": "number" }
      }
    }
  }
}
