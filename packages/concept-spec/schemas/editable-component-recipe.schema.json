{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json",
  "title": "EditableComponentRecipe",
  "description": "Reviewed, non-executable visual component recipe. Runtime validates frame orthonormality, child graph acyclicity, budgets and referenced content hashes before expansion.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "recipe_id", "version", "component_role", "display_name", "description", "profiles", "section_sets", "shape_program_template", "feature_template", "parameter_bindings", "connectors", "pivot", "root_local_transform", "material_zones", "child_slots", "allowed_domains", "triangle_estimate", "quality_status", "source", "license", "review_state", "non_functional_only"],
  "properties": {
    "schema_version": { "const": "EditableComponentRecipe@1" },
    "recipe_id": { "type": "string", "pattern": "^recipe_[a-z0-9_\\-]+$" },
    "version": { "type": "integer", "minimum": 1, "maximum": 9999 },
    "component_role": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" },
    "display_name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "minLength": 1, "maxLength": 400 },
    "profiles": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/profile_refs" },
    "section_sets": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/section_set_refs" },
    "shape_program_template": { "$ref": "shape-program.schema.json" },
    "feature_template": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/geometry_feature" } },
    "parameter_bindings": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/editable_parameter_binding" } },
    "connectors": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/connector" } },
    "pivot": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/frame" },
    "root_local_transform": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/local_transform" },
    "material_zones": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/material_zone" } },
    "surface_adornment_slots": { "type": "array", "maxItems": 8, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/surface_adornment_slot" } },
    "child_slots": { "type": "array", "maxItems": 12, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/child_slot" } },
    "allowed_domains": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/domain" } },
    "triangle_estimate": { "type": "integer", "minimum": 100, "maximum": 100000, "description": "Reviewed upper bound for the expanded recipe output; runtime validates actual readback triangles do not exceed it." },
    "quality_status": { "const": "passed" },
    "source": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/source" },
    "license": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/license" },
    "review_state": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/review" },
    "non_functional_only": { "const": true }
  },
  "$defs": {
    "domain": { "type": "string", "enum": ["pack_future_weapon_prop", "pack_vehicle_concept", "pack_aircraft_concept", "pack_robotic_arm_concept"] },
    "vec3_unit": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number", "minimum": -1, "maximum": 1 } },
    "point_mm": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number", "minimum": -10000, "maximum": 10000 } },
    "frame": {
      "type": "object", "additionalProperties": false,
      "required": ["position", "normal", "up"],
      "properties": {
        "position": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/point_mm" },
        "normal": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/vec3_unit", "description": "Unit normal; must be orthogonal to up at runtime." },
        "up": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/vec3_unit", "description": "Unit up; normal cross up forms the right-handed tangent." }
      }
    },
    "connector": { "type": "object", "additionalProperties": false, "required": ["connector_id", "kind", "position", "normal", "up"], "properties": { "connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" }, "kind": { "type": "string", "enum": ["visual_mount", "shell_join", "trim_join", "display_support"] }, "position": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/point_mm" }, "normal": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/vec3_unit", "description": "Unit normal; must be orthogonal to up at runtime." }, "up": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/vec3_unit", "description": "Unit up; normal cross up forms the right-handed tangent." } } },
    "profile_refs": { "type": "array", "maxItems": 12, "items": { "type": "object", "additionalProperties": false, "required": ["profile_input_id", "profile_sketch_id"], "properties": { "profile_input_id": { "type": "string", "pattern": "^profileinput_[a-z0-9_\\-]+$" }, "profile_sketch_id": { "type": "string", "pattern": "^sketch_[a-z0-9_\\-]+$" } } } },
    "section_set_refs": { "type": "array", "maxItems": 12, "items": { "type": "object", "additionalProperties": false, "required": ["section_set_id", "sha256", "canonical_payload"], "properties": { "section_set_id": { "type": "string", "pattern": "^sectionset_[a-z0-9_\\-]+$" }, "sha256": { "$ref": "common.schema.json#/$defs/sha256" }, "canonical_payload": { "$ref": "profile-section-set.schema.json" } } } },
    "geometry_feature": { "type": "object", "additionalProperties": false, "required": ["feature_id", "operation_id", "role"], "properties": { "feature_id": { "type": "string", "pattern": "^feature_[a-z0-9_\\-]+$" }, "operation_id": { "type": "string", "pattern": "^op_[a-z0-9_\\-]+$" }, "role": { "type": "string", "enum": ["primary_form", "secondary_form", "cabin_form", "base_form", "upper_link_form", "end_effector_form", "trim", "visual_detail"] } } },
    "material_zone": { "type": "object", "additionalProperties": false, "required": ["zone_id", "role", "material_preset_id"], "properties": { "zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" }, "role": { "type": "string", "enum": ["shell", "trim", "glass", "rubber", "signal", "decal"] }, "material_preset_id": { "type": "string", "pattern": "^mat_[a-z0-9_\\-]+$" } } },
    "surface_adornment_slot": { "type": "object", "additionalProperties": false, "required": ["slot_id", "zone_id", "allowed_kinds", "allowed_motifs", "allowed_coverages"], "properties": { "slot_id": { "type": "string", "pattern": "^adornslot_[a-z0-9_\\-]+$" }, "zone_id": { "type": "string", "pattern": "^zone_[a-z0-9_\\-]+$" }, "allowed_kinds": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "enum": ["normal_relief", "pattern", "flowline", "micro_surface"] } }, "allowed_motifs": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "enum": ["parallel_groove", "chevron_relief", "double_flowline", "hex_microgrid"] } }, "allowed_coverages": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "enum": ["full_zone", "center_band", "edge_band", "symmetric_pair"] } } } },
    "child_slot": { "type": "object", "additionalProperties": false, "required": ["slot_id", "accepted_roles", "child_recipe_id", "parent_connector_id", "child_connector_id", "parent_local_transform", "required"], "properties": { "slot_id": { "type": "string", "pattern": "^slot_[a-z0-9_\\-]+$" }, "accepted_roles": { "type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" } }, "child_recipe_id": { "type": "string", "pattern": "^recipe_[a-z0-9_\\-]+$" }, "parent_connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" }, "child_connector_id": { "type": "string", "pattern": "^connector_[a-z0-9_\\-]+$" }, "parent_local_transform": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/local_transform" }, "required": { "type": "boolean" } } },
    "local_transform": { "type": "object", "additionalProperties": false, "required": ["position", "rotation", "scale"], "properties": { "position": { "$ref": "https://forgecad.local/schemas/concept/editable-component-recipe.schema.json#/$defs/point_mm" }, "rotation": { "description": "Euler XYZ radians, intentionally separate from connector unit vectors.", "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number", "minimum": -3.141592653589793, "maximum": 3.141592653589793 } }, "scale": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number", "exclusiveMinimum": 0, "maximum": 4 } } } },
    "source": { "type": "object", "additionalProperties": false, "required": ["source_kind", "source_id"], "properties": { "source_kind": { "type": "string", "enum": ["forgecad_first_party"] }, "source_id": { "type": "string", "pattern": "^source_[a-z0-9_\\-]+$" } } },
    "license": { "type": "object", "additionalProperties": false, "required": ["license_id", "redistributable"], "properties": { "license_id": { "const": "ForgeCAD-Internal-Visual-Only" }, "redistributable": { "const": false } } },
    "review": { "type": "object", "additionalProperties": false, "required": ["review_id", "reviewed_at", "reviewer_kind"], "properties": { "review_id": { "type": "string", "pattern": "^review_[a-z0-9_\\-]+$" }, "reviewed_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }, "reviewer_kind": { "const": "forgecad_internal" } } }
  }
}
