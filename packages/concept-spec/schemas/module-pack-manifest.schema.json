{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/module-pack-manifest.schema.json",
  "title": "ModulePackManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "profile_id",
    "name",
    "version",
    "description",
    "intended_uses",
    "non_functional_only",
    "units",
    "up_axis",
    "forward_axis",
    "handedness",
    "license",
    "modules"
  ],
  "properties": {
    "schema_version": { "const": "ModulePackManifest@1" },
    "pack_id": { "$ref": "common.schema.json#/$defs/id" },
    "profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "intended_uses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/intended_use" }
    },
    "non_functional_only": { "const": true },
    "units": { "const": "millimeter" },
    "up_axis": { "const": "Y" },
    "forward_axis": { "const": "-Z" },
    "handedness": { "const": "right" },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx_expression", "license_path"],
      "properties": {
        "spdx_expression": { "type": "string", "minLength": 1, "maxLength": 120 },
        "license_path": { "$ref": "common.schema.json#/$defs/relative_path" }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module_id",
          "manifest_path",
          "glb_path",
          "thumbnail_path",
          "license_path",
          "lod"
        ],
        "properties": {
          "module_id": { "$ref": "common.schema.json#/$defs/id" },
          "manifest_path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "glb_path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "thumbnail_path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "license_path": { "$ref": "common.schema.json#/$defs/relative_path" },
          "lod": { "enum": ["LOD0", "LOD1", "LOD2"] }
        }
      }
    }
  }
}
