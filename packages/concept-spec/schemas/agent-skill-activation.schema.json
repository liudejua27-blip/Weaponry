{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/agent-skill-activation.schema.json",
  "title": "AgentSkillActivation",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "activation_id", "skill_id", "skill_version", "skill_sha256", "enabled", "updated_at"],
  "properties": {
    "schema_version": { "const": "AgentSkillActivation@1" },
    "activation_id": { "type": "string", "pattern": "^skillact_[a-z0-9_\\-]+$" },
    "skill_id": { "type": "string", "pattern": "^skill_[a-z0-9_\\-]+$" },
    "skill_version": { "type": "integer", "minimum": 1 },
    "skill_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "enabled": { "type": "boolean" },
    "updated_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
