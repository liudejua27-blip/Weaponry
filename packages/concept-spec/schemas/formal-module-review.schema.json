{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/formal-module-review.schema.json",
  "title": "FormalModuleReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "scope",
    "pack_id",
    "pack_version",
    "pack_manifest_sha256",
    "pack_license_sha256",
    "author_id",
    "reviewer",
    "reviewed_at",
    "approval_status",
    "reviewer_attestation",
    "limitations_acknowledged",
    "pack_review",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "const": "FormalModuleReview@1"
    },
    "review_id": {
      "type": "string",
      "pattern": "^fmr_[a-z0-9_]{8,80}$"
    },
    "scope": {
      "enum": ["first_three", "release_10_12"]
    },
    "pack_id": {
      "type": "string",
      "pattern": "^pack_[a-z][a-z0-9_]*_v[0-9]+$"
    },
    "pack_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "pack_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pack_license_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "author_id": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id", "display_name", "role"],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "display_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "role": {
          "enum": ["art_director", "technical_artist", "asset_reviewer"]
        },
        "organization": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        }
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "approval_status": {
      "enum": ["changes_requested", "approved"]
    },
    "reviewer_attestation": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500
    },
    "limitations_acknowledged": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "enum": [
          "non_functional_concept_asset",
          "not_manufacturing_documentation",
          "not_structural_or_safety_validation"
        ]
      }
    },
    "pack_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_ids_preserved",
        "connector_semantics_preserved",
        "license_reviewed",
        "source_export_reproducible",
        "intended_uses_verified",
        "human_final_art_approved",
        "notes"
      ],
      "properties": {
        "stable_ids_preserved": {"type": "boolean"},
        "connector_semantics_preserved": {"type": "boolean"},
        "license_reviewed": {"type": "boolean"},
        "source_export_reproducible": {"type": "boolean"},
        "intended_uses_verified": {"type": "boolean"},
        "human_final_art_approved": {"type": "boolean"},
        "notes": {
          "type": "string",
          "minLength": 12,
          "maxLength": 1200
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module_id",
          "source_blend_file",
          "source_blend_sha256",
          "module_manifest_sha256",
          "glb_sha256",
          "thumbnail_sha256",
          "license_sha256",
          "review"
        ],
        "properties": {
          "module_id": {
            "type": "string",
            "pattern": "^module_[a-z][a-z0-9_]*_[0-9]{2}$"
          },
          "source_blend_file": {
            "type": "string",
            "pattern": "^module_[a-z][a-z0-9_]*_[0-9]{2}\\.blend$"
          },
          "source_blend_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "module_manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "glb_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "thumbnail_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "license_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "silhouette_distinct",
              "surface_hierarchy_reviewed",
              "material_partition_reviewed",
              "uv0_reviewed",
              "thumbnail_reviewed",
              "connector_contract_reviewed",
              "transforms_and_modifiers_reviewed",
              "non_functional_visual_only",
              "scores",
              "notes"
            ],
            "properties": {
              "silhouette_distinct": {"type": "boolean"},
              "surface_hierarchy_reviewed": {"type": "boolean"},
              "material_partition_reviewed": {"type": "boolean"},
              "uv0_reviewed": {"type": "boolean"},
              "thumbnail_reviewed": {"type": "boolean"},
              "connector_contract_reviewed": {"type": "boolean"},
              "transforms_and_modifiers_reviewed": {"type": "boolean"},
              "non_functional_visual_only": {"type": "boolean"},
              "scores": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "silhouette",
                  "surface_hierarchy",
                  "material_readability",
                  "modular_readability",
                  "thumbnail_quality"
                ],
                "properties": {
                  "silhouette": {"type": "integer", "minimum": 1, "maximum": 5},
                  "surface_hierarchy": {"type": "integer", "minimum": 1, "maximum": 5},
                  "material_readability": {"type": "integer", "minimum": 1, "maximum": 5},
                  "modular_readability": {"type": "integer", "minimum": 1, "maximum": 5},
                  "thumbnail_quality": {"type": "integer", "minimum": 1, "maximum": 5}
                }
              },
              "notes": {
                "type": "string",
                "minLength": 12,
                "maxLength": 1200
              }
            }
          }
        }
      }
    }
  }
}
