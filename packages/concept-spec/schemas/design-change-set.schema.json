{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/design-change-set.schema.json",
  "title": "DesignChangeSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_set_id", "project_id", "base_version_id", "summary", "operations", "protected_node_ids", "status"],
  "properties": {
    "schema_version": { "const": "DesignChangeSet@1" },
    "change_set_id": { "$ref": "common.schema.json#/$defs/id" },
    "project_id": { "$ref": "common.schema.json#/$defs/id" },
    "base_version_id": { "$ref": "common.schema.json#/$defs/id" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation_id", "op"],
        "properties": {
          "operation_id": { "type": "string", "pattern": "^op_[A-Za-z0-9_\\-]+$" },
          "op": { "type": "string", "enum": ["add_module", "remove_module", "replace_module", "connect", "disconnect", "set_transform", "set_style", "set_parameter"] },
          "node_id": { "$ref": "common.schema.json#/$defs/id" },
          "module_id": { "$ref": "common.schema.json#/$defs/id" },
          "edge_id": { "$ref": "common.schema.json#/$defs/id" },
          "from_node_id": { "$ref": "common.schema.json#/$defs/id" },
          "from_connector_id": { "$ref": "common.schema.json#/$defs/id" },
          "to_node_id": { "$ref": "common.schema.json#/$defs/id" },
          "to_connector_id": { "$ref": "common.schema.json#/$defs/id" },
          "path": { "type": "string", "minLength": 1 },
          "value": {},
          "transform": { "$ref": "common.schema.json#/$defs/transform" }
        }
      }
    },
    "protected_node_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "common.schema.json#/$defs/id" } },
    "status": { "type": "string", "enum": ["proposed", "previewed", "confirmed", "rejected", "stale"] }
  }
}
