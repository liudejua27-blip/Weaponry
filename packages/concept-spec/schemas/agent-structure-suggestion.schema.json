{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/agent-structure-suggestion.schema.json",
  "title": "AgentStructureSuggestionList",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "asset_version_id", "suggestions", "unavailable_message"],
  "properties": {
    "schema_version": { "const": "AgentStructureSuggestionList@1" },
    "asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
    "suggestions": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "suggestion_id", "kind", "asset_version_id", "part_id", "target_part_id", "affected_part_ids", "source_facts", "summary"],
        "properties": {
          "schema_version": { "const": "AgentStructureSuggestion@1" },
          "suggestion_id": { "type": "string", "pattern": "^structure_[a-z0-9_\\-]+$" },
          "kind": { "type": "string", "enum": ["split_part", "merge_parts"] },
          "asset_version_id": { "type": "string", "pattern": "^assetver_[a-z0-9_\\-]+$" },
          "part_id": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" },
          "target_part_id": { "type": ["string", "null"], "pattern": "^part_[a-z0-9_\\-]+$" },
          "affected_part_ids": { "type": "array", "minItems": 1, "maxItems": 4, "items": { "type": "string", "pattern": "^part_[a-z0-9_\\-]+$" } },
          "source_facts": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "type": "string" } },
          "summary": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "unavailable_message": { "type": ["string", "null"], "maxLength": 240 }
  }
}
