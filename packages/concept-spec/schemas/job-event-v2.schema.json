{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgecad.local/schemas/concept/job-event-v2.schema.json",
  "title": "JobEventV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "job_id", "seq", "project_id", "step", "level", "status", "message", "progress", "metadata", "created_at"],
  "properties": {
    "schema_version": { "const": "JobEvent@2" },
    "event_id": { "$ref": "common.schema.json#/$defs/id" },
    "job_id": { "$ref": "common.schema.json#/$defs/id" },
    "seq": { "type": "integer", "minimum": 1 },
    "project_id": { "$ref": "common.schema.json#/$defs/id" },
    "version_id": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/id" },
        { "type": "null" }
      ]
    },
    "step": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["info", "warning", "error"] },
    "status": { "type": "string", "enum": ["created", "queued", "running", "waiting_provider", "waiting_user", "retrying", "succeeded", "failed", "cancelled", "partial_succeeded"] },
    "message": { "type": "string", "minLength": 1 },
    "progress": { "type": "number", "minimum": 0, "maximum": 1 },
    "artifact_asset_id": {
      "anyOf": [
        { "$ref": "common.schema.json#/$defs/id" },
        { "type": "null" }
      ]
    },
    "metadata": { "type": "object" },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
