{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wushen-forge.local/schemas/asset-record.schema.json",
  "title": "AssetRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "asset_id", "weapon_spec_id", "versions", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "AssetRecord@1" },
    "asset_id": { "$ref": "common.schema.json#/$defs/id" },
    "weapon_spec_id": { "$ref": "common.schema.json#/$defs/id" },
    "current_version_id": { "$ref": "common.schema.json#/$defs/id" },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version_id", "version", "type", "files", "job_id", "created_at"],
        "properties": {
          "version_id": { "$ref": "common.schema.json#/$defs/id" },
          "version": { "type": "integer", "minimum": 1 },
          "parent_version_id": { "$ref": "common.schema.json#/$defs/id" },
          "type": { "type": "string", "enum": ["concept_image", "concept_patch", "model_rough", "unity_export"] },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file_id", "role", "logical_path", "object_path", "sha256", "byte_size", "mime_type", "ext"],
              "properties": {
                "file_id": { "$ref": "common.schema.json#/$defs/id" },
                "role": { "type": "string" },
                "logical_path": { "$ref": "common.schema.json#/$defs/relative_path" },
                "object_path": { "$ref": "common.schema.json#/$defs/relative_path" },
                "sha256": { "$ref": "common.schema.json#/$defs/sha256" },
                "byte_size": { "type": "integer", "minimum": 0 },
                "mime_type": { "type": "string" },
                "ext": { "type": "string" },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "job_id": { "$ref": "common.schema.json#/$defs/id" },
          "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
        }
      }
    },
    "current_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "path", "provider", "status"],
      "properties": {
        "model_id": { "$ref": "common.schema.json#/$defs/id" },
        "path": { "$ref": "common.schema.json#/$defs/relative_path" },
        "provider": { "$ref": "common.schema.json#/$defs/provider" },
        "status": { "type": "string", "enum": ["rough_preview", "normalized", "optimized", "unity_exported", "failed"] }
      }
    },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" },
    "updated_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
