{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wushen-forge.local/schemas/skill-graph.schema.json",
  "title": "SkillGraph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_graph_id",
    "weapon_id",
    "origin_graph_id",
    "source_interpretation_id",
    "skills",
    "non_manufacturing_asset",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "SkillGraph@1" },
    "skill_graph_id": { "$ref": "common.schema.json#/$defs/id" },
    "weapon_id": { "$ref": "common.schema.json#/$defs/id" },
    "origin_graph_id": { "$ref": "common.schema.json#/$defs/id" },
    "source_interpretation_id": { "$ref": "common.schema.json#/$defs/id" },
    "skills": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot", "name", "trigger", "effect", "anchor_point", "combat_affordances"],
        "properties": {
          "slot": { "type": "string", "enum": ["normal", "heavy", "mobility_or_defense", "control", "passive", "ultimate"] },
          "name": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 },
          "effect": { "type": "string", "minLength": 1 },
          "anchor_point": { "type": "string", "minLength": 1 },
          "combat_affordances": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "cooldown_hint": { "type": "string" },
          "cost_hint": { "type": "string" }
        }
      }
    },
    "non_manufacturing_asset": { "const": true },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
