{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wushen-forge.local/schemas/patch-manifest.schema.json",
  "title": "PatchManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "weapon_id", "source_asset_id", "source_image", "mask_asset_id", "mask_image", "selection", "instruction", "preserve", "strength", "created_at"],
  "properties": {
    "schema_version": { "const": "PatchManifest@1" },
    "weapon_id": { "$ref": "common.schema.json#/$defs/id" },
    "source_asset_id": { "$ref": "common.schema.json#/$defs/id" },
    "source_image": { "$ref": "common.schema.json#/$defs/relative_path" },
    "mask_asset_id": { "$ref": "common.schema.json#/$defs/id" },
    "mask_image": { "$ref": "common.schema.json#/$defs/relative_path" },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "polygon"],
      "properties": {
        "tool": { "type": "string", "enum": ["brush", "lasso", "polygon", "rectangle"] },
        "polygon": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        }
      }
    },
    "canvas_transform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scale": { "type": "number" },
        "rotation": { "type": "number" },
        "offset_x": { "type": "number" },
        "offset_y": { "type": "number" }
      }
    },
    "instruction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "text"],
      "properties": {
        "target": { "type": "string", "enum": ["blade", "guard", "core", "rune", "glow", "material", "silhouette", "handle", "ornament", "whole_weapon"] },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "preserve": {
      "type": "array",
      "items": { "type": "string", "enum": ["overall_silhouette", "chinese_motifs", "toon_outline", "main_palette", "material_zones", "weapon_identity"] }
    },
    "strength": { "type": "string", "enum": ["subtle", "medium", "strong"] },
    "regenerate_3d": { "type": "boolean" },
    "created_at": { "$ref": "common.schema.json#/$defs/iso_datetime" }
  }
}
