{
  "template_id": "wushen_concept_sd_basic",
  "template_version": "0.1.0",
  "description": "Minimal ComfyUI API-format concept workflow for Wushen Forge. Replace with an exported API workflow for production art direction.",
  "default_checkpoint": "v1-5-pruned-emaonly.safetensors",
  "bindings": {
    "checkpoint": { "node": "4", "input": "ckpt_name" },
    "positive_prompt": { "node": "6", "input": "text" },
    "negative_prompt": { "node": "7", "input": "text" },
    "seed": { "node": "3", "input": "seed" },
    "width": { "node": "5", "input": "width" },
    "height": { "node": "5", "input": "height" },
    "filename_prefix": { "node": "9", "input": "filename_prefix" }
  },
  "prompt": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 1,
        "steps": 24,
        "cfg": 7,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "v1-5-pruned-emaonly.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1280,
        "height": 720,
        "batch_size": 1
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "3渲2国风神兵，虚构 Unity 游戏资产，逼真外观，非制造说明",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "real weapon blueprint, manufacturing drawing, dimensions, material formula, machining steps",
        "clip": ["4", 1]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "wushen/concept",
        "images": ["8", 0]
      }
    }
  }
}
