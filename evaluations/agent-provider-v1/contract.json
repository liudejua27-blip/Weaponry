{
  "schema_version": "ForgeCADProviderEvaluationContract@1",
  "evaluation_id": "general_mechanical_provider_v1",
  "product_scope": "non_functional_concept_assets_only",
  "default_execution": "dry_run",
  "live_execution": {
    "status": "external_authorization_required",
    "required_operator_flags": [
      "--confirm-live-provider",
      "--confirmed-budget-cny",
      "--evaluation-run-id"
    ],
    "required_human_records": [
      "operator_name",
      "approved_budget_cny",
      "approval_timestamp",
      "provider_connection_preflight"
    ],
    "automatic_invocation_forbidden": [
      "ci",
      "first_launch",
      "ordinary_agent_turn",
      "retry_after_failure"
    ]
  },
  "case_plan": {
    "normal_cases_per_domain": 20,
    "domain_count": 4,
    "clarification_or_rejection_cases": 20,
    "total_planned_cases": 100,
    "normal_provider_requests": 80
  },
  "budget": {
    "default_spend_cap_cny": 0,
    "max_operator_approved_budget_cny": 100,
    "max_provider_requests": 80,
    "max_retries_per_case": 0,
    "max_request_timeout_seconds": 45,
    "max_output_tokens_per_request": 1200,
    "max_total_output_tokens": 120000,
    "max_total_tokens_when_usage_is_reported": 720000,
    "live_budget_must_be_operator_declared": true,
    "stop_before_next_request_when_budget_or_request_limit_is_reached": true
  },
  "acceptance": {
    "normal_domain_binding_rate": 1.0,
    "normal_structured_output_rate": 1.0,
    "normal_three_complete_directions_rate": 0.95,
    "normal_non_functional_scope_rate": 1.0,
    "clarification_or_rejection_safe_stop_rate": 1.0,
    "asset_or_snapshot_writes_before_confirmation": 0,
    "token_usage_coverage_for_eligible_live_evidence": 1.0
  },
  "evidence": {
    "store_raw_prompts": false,
    "store_raw_provider_responses": false,
    "store_api_key": false,
    "store_base_url": false,
    "store_model_identifier": false,
    "allowed_per_case_fields": [
      "case_id",
      "fixture_sha256",
      "domain_pack_id",
      "outcome_category",
      "structured_output_valid",
      "direction_count",
      "safety_checks",
      "latency_ms",
      "input_tokens",
      "output_tokens",
      "total_tokens"
    ],
    "failure_categories": [
      "timeout",
      "rate_limited",
      "authentication_failed",
      "transport_failed",
      "invalid_structured_output",
      "policy_scope_failed",
      "budget_exceeded",
      "cancelled"
    ]
  }
}
